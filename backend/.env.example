# Plantilla de variables de entorno para el clasificador de tickets
# Copia este fichero a .env en la raíz del repo y rellena los valores

AZURE_DEVOPS_ORG_URL=https://dev.azure.com/<tu-organizacion>
AZURE_DEVOPS_PROJECT=<nombre-del-proyecto>
AZURE_DEVOPS_PAT=<personal-access-token>

AZURE_OPENAI_ENDPOINT=https://<recurso>.openai.azure.com/
AZURE_OPENAI_API_KEY=<api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
